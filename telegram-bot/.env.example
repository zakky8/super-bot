# Telegram Bot Configuration

# ── Bot Token ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/telegram_bot
POSTGRES_PASSWORD=your_postgres_password_here

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Admin IDs (comma-separated Telegram user IDs) ─────────────────────────────
ADMIN_IDS=123456789,987654321

# ── Anthropic Claude AI ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model: claude-sonnet-4-6 | claude-opus-4-5 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6
# Name shown in AI responses
BOT_NAME=SupportBot
# Telegram Chat ID for human escalation alerts (optional)
HUMAN_MODERATOR_CHAT_ID=

# ── Ollama (local fallback, optional) ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
