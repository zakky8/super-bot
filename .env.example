# Bot System V2 — Root Environment Configuration
# Copy to .env and fill in your values before running

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Channel ID to receive AI escalation notifications (optional)
HUMAN_MODERATOR_CHANNEL=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789,987654321
# Telegram Chat ID that receives escalation / support alerts (optional)
HUMAN_MODERATOR_CHAT_ID=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=strongpassword
DATABASE_URL=postgresql://botuser:strongpassword@postgres:5432/bot_system

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=strongredispassword
REDIS_URL=redis://:strongredispassword@redis:6379

# ── Anthropic Claude AI ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model to use (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6 | claude-opus-4-5 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6
# Display name used in AI responses
BOT_NAME=SupportBot

# ── Ollama (local fallback, optional) ────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
