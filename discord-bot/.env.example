# Discord Bot Configuration

# ── Bot Credentials ────────────────────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/discord_bot
POSTGRES_PASSWORD=your_postgres_password_here

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Anthropic Claude AI ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model: claude-sonnet-4-6 | claude-opus-4-5 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6
# Name shown in AI responses
BOT_NAME=SupportBot
# Discord channel ID for human escalation alerts (optional)
HUMAN_MODERATOR_CHANNEL=

# ── Ollama (local fallback, optional) ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
